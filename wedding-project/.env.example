# Переменные окружения для Docker Compose
# Скопируйте этот файл в .env и заполните своими данными

# Telegram Bot Token (получить у @BotFather)
TG_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (куда отправлять уведомления)
TG_CHAT_ID=your_chat_id_here

# Секретный ключ для API (можно оставить по умолчанию или изменить)
API_SECRET=wedding_secret_2026
